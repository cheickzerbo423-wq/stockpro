# ============================================================
# WariGest Backend — Variables d'environnement
# Pour Railway : Service > Variables > ajouter chacune
# Pour local   : copier en .env
# ============================================================

# ─── OBLIGATOIRES ───────────────────────────────────────────

# Clé secrète JWT — OBLIGATOIRE (générer avec :)
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGEZ_CETTE_CLE_SECRETE_EN_PRODUCTION

# URL PostgreSQL — Railway la fournit automatiquement si vous avez
# un service PostgreSQL lié dans le même projet Railway
# DATABASE_URL=postgresql://user:password@host:port/database

# ─── OPTIONNELLES ───────────────────────────────────────────

# Durée d'expiration du token JWT (défaut : 8h)
JWT_EXPIRES_IN=8h

# Environnement
NODE_ENV=production

# URL du frontend Vercel (pour CORS explicite)
FRONTEND_URL=https://stockpro-omega.vercel.app

# Infos entreprise pour les PDFs (optionnelles)
COMPANY_NAME=Mon Entreprise
COMPANY_ADDRESS=Adresse complète
COMPANY_PHONE=+225 00 00 00 00
COMPANY_EMAIL=contact@monentreprise.com
COMPANY_DEVISE=FCFA

# ─── DÉVELOPPEMENT LOCAL uniquement ─────────────────────────
# (ignoré si DATABASE_URL est défini)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=warigest_db
# DB_USER=warigest_user
# DB_PASSWORD=votre_mot_de_passe
